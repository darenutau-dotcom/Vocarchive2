        .play-btn { background: #d81b60; border: none; color: white; padding: 5px 12px; font-size: 0.8rem; font-weight: bold; border-radius: 3px; cursor: pointer; }

        .card-body { padding: 15px; display: flex; flex-direction: column; flex-grow: 1; gap: 8px; }
        .character-id { font-size: 0.75rem; color: #999; font-weight: bold; text-transform: uppercase; }
        .card-title { font-size: 1.1rem; font-weight: bold; color: #111; text-transform: uppercase; }
        
        .meta-line { font-size: 0.8rem; color: #666; }
