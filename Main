        /* VENTANA MODAL (Pantalla Desplegable "Ver Más") */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); justify-content: center; align-items: center; z-index: 1000; padding: 20px; }
        .modal-content { background: white; width: 100%; max-width: 700px; max-height: 85vh; border-radius: 8px; padding: 25px; overflow-y: auto; position: relative; }
        .close-modal { position: absolute; top: 15px; right: 20px; font-size: 1.8rem; cursor: pointer; color: #666; }
        .modal-title { font-size: 1.5rem; margin-bottom: 5px; color: #111; }
        .modal-subtitle { font-size: 0.9rem; color: #666; margin-bottom: 20px; border-bottom: 2px solid #eee; padding-bottom: 10px; }
        
        /* Lista de Versiones dentro del Modal */
        .version-item { background: #f8f9fa; border: 1px solid #e9ecef; padding: 15px; border-radius: 6px; margin-bottom: 15px; display: flex; gap: 15px; position: relative;}
