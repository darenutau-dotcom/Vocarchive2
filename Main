    <div class="main-layout">
        <aside class="form-section">
            <h2>Subir Voicebank</h2>
            <form id="voicebankForm">
                <div class="form-group">
                    <label for="vbId">Character ID (Ej: MIKU, IA, LENO):</label>
                    <input type="text" id="vbId" placeholder="Ej: MIKU" required style="text-transform: uppercase;">
                </div>
                <div class="form-group">
                    <label for="vbName">Nombre de la Versión/Append:</label>
                    <input type="text" id="vbName" placeholder="Ej: Hatsune Miku V4X Dark" required>
                </div>
                <div class="form-group">
                    <label for="vbDemo">URL Demo Song (Audio):</label>
                    <input type="url" id="vbDemo" placeholder="https://ejemplo.com/audio.mp3" required>
                </div>
                <div class="form-group">
                    <label for="vbImg">URL Imagen de esta versión:</label>
                    <input type="url" id="vbImg" placeholder="https://ejemplo.com/imagen.jpg" required>
                </div>
                <div class="form-group">
                    <label for="vbLang">Idioma(s) (Separados por comas):</label>
                    <input type="text" id="vbLang" placeholder="Ej: Japonés, Inglés" required>
                </div>
                <div class="form-group">
                    <label for="vbSoftware">Software / Plataforma:</label>
                    <input type="text" id="vbSoftware" placeholder="Ej: VOCALOID4" required>
                </div>
                <div class="form-group">
                    <label for="vbDate">Fecha de Lanzamiento:</label>
                    <input type="date" id="vbDate" required>
                </div>
                <div class="form-group">
                    <label for="vbGender">Género de Voz:</label>
                    <select id="vbGender">
                        <option value="Femenino">Femenino</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Ambos / Otro">Ambos / Otro</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="vbWeb">Official Website (URL):</label>
                    <input type="url" id="vbWeb" placeholder="https://..." required>
                </div>
                <button type="submit" class="btn-submit">Registrar Versión</button>
            </form>
        </aside>

        <main class="catalog-section">
            <input type="text" id="searchBar" class="search-bar" placeholder="Buscar por personaje, versión, idioma, plataforma...">
            
            <div id="catalogGrid" class="catalog-grid"></div>
