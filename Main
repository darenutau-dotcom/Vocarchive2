<div id="versionsModal" class="modal">
    <div class="modal-content">
        <span class="close-modal" onclick="closeModal()">&times;</span>
        <h2 id="modalCharacterTitle" class="modal-title">Nombre del Personaje</h2>
        <p id="modalCharacterSubtitle" class="modal-subtitle">ID: MIKU</p>
        <div id="versionsList">
            </div>
