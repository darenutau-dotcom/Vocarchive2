<audio id="globalAudioPlayer"></audio>

<script>
    // Base de datos simulada estructurada por Carpetas de ID Único
    // Cada ID tiene un array de "versions". La última del array se considera la más reciente.
    let characterArchive = JSON.parse(localStorage.getItem('characterArchive')) || {
        "MIKU": {
            id: "MIKU",
            versions: [
                {
                    name: "Hatsune Miku V2",
                    demo: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3",
                    img: "https://images.unsplash.com/photo-1607604276583-eef5d076aa5f?w=400",
                    lang: "Japonés",
                    software: "VOCALOID2",
                    date: "2007-08-31",
                    gender: "Femenino",
                    web: "https://piapro.net"
                },
                {
                    name: "Hatsune Miku V4X Dark",
                    demo: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3",
                    img: "https://images.unsplash.com/photo-1578632767115-351597cf2477?w=400",
                    lang: "Japonés, Inglés",
                    software: "VOCALOID4",
                    date: "2016-08-31",
                    gender: "Femenino",
                    web: "https://crypton.co.jp"
                }
            ]
        }
    };

    const itemsPerPage = 12;
    let currentPage = 1;
    let filteredIds = [];

    const form = document.getElementById('voicebankForm');
    const catalogGrid = document.getElementById('catalogGrid');
    const searchBar = document.getElementById('searchBar');
    const paginationContainer = document.getElementById('pagination');
    const globalAudio = document.getElementById('globalAudioPlayer');

    // Al guardar un formulario
    form.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const idInput = document.getElementById('vbId').value.trim().toUpperCase();
        
        const newVersion = {
            name: document.getElementById('vbName').value,
            demo: document.getElementById('vbDemo').value,
            img: document.getElementById('vbImg').value,
            lang: document.getElementById('vbLang').value,
            software: document.getElementById('vbSoftware').value,
            date: document.getElementById('vbDate').value,
            gender: document.getElementById('vbGender').value,
            web: document.getElementById('vbWeb').value
        };

        // Si el ID de personaje no existe, lo creamos vacío
        if (!characterArchive[idInput]) {
            characterArchive[idInput] = {
                id: idInput,
                versions: []
            };
        }

        // Agregamos la nueva versión al final del historial (es la más reciente)
        characterArchive[idInput].versions.push(newVersion);

        // Guardar cambios
        localStorage.setItem('characterArchive', JSON.stringify(characterArchive));
        form.reset();
        applyFilterAndRender();
    });

    // Renderizar el catálogo principal
    function renderCatalog(page) {
        catalogGrid.innerHTML = "";
        
        if (filteredIds.length === 0) {
            catalogGrid.innerHTML = "<p style='grid-column:1/-1; text-align:center; padding:20px;'>No se encontraron personajes.</p>";
            paginationContainer.innerHTML = "";
            return;
        }

        let start = (page - 1) * itemsPerPage;
        let end = start + itemsPerPage;
        let paginatedIds = filteredIds.slice(start, end);

        paginatedIds.forEach(id => {
            const character = characterArchive[id];
            // La versión más reciente es la ÚLTIMA del arreglo
            const latest = character.versions[character.versions.length - 1];

            const card = document.createElement('article');
            card.className = 'card';
            card.innerHTML = `
                <div class="card-img-box">
                    <img src="${latest.img}" alt="${latest.name}" onerror="this.src='https://via.placeholder.com/250?text=No+Image'">
                    <div class="audio-player-box">
                        <button class="play-btn" onclick="playAudio('${latest.demo}', this)">▶ DEMO RECIENTE</button>
                    </div>
                </div>
                <div class="card-body">
                    <span class="character-id">ID: ${character.id}</span>
                    <h3 class="card-title">${latest.name}</h3>
                    <div class="meta-line"><strong>Género:</strong> ${latest.gender}</div>
                    <div class="meta-line"><strong>Idiomas:</strong></div>
                    <div class="tags-container">
                        ${latest.lang.split(',').map(l => `<span class="tag">${l.trim()}</span>`).join('')}
                    </div>
                    <div class="meta-line" style="margin-top:5px;"><strong>Plataforma:</strong></div>
                    <div class="tags-container">
                        <span class="tag" style="background:#e3f2fd; color:#0d47a1;">${latest.software}</span>
                    </div>
                    <button class="btn-view-more" onclick="openModal('${character.id}')">Ver Versiones (${character.versions.length})</button>
                </div>
            `;
            catalogGrid.appendChild(card);
        });

        renderPagination();
    }

    // Paginación de IDs de personajes
    function renderPagination() {
        paginationContainer.innerHTML = "";
        const totalPages = Math.ceil(filteredIds.length / itemsPerPage);
        if (totalPages <= 1) return;

        for (let i = 1; i <= totalPages; i++) {
            const btn = document.createElement('button');
            btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
            btn.innerText = i;
            btn.addEventListener('click', () => {
                currentPage = i;
                renderCatalog(currentPage);
            });
            paginationContainer.appendChild(btn);
        }
    }

    // Buscador: Busca coincidencias en CUALQUIERA de las versiones de un personaje
    function applyFilterAndRender() {
        const query = searchBar.value.toLowerCase().trim();
        
        filteredIds = Object.keys(characterArchive).filter(id => {
            const character = characterArchive[id];
            // Un personaje pasa el filtro si su ID coincide, o si AL MENOS una de sus versiones coincide
            const matchId = character.id.toLowerCase().includes(query);
            const matchVersions = character.versions.some(v => 
                v.name.toLowerCase().includes(query) ||
                v.software.toLowerCase().includes(query) ||
                v.lang.toLowerCase().includes(query) ||
                v.gender.toLowerCase().includes(query)
            );
            return matchId || matchVersions;
        });

        currentPage = 1;
        renderCatalog(currentPage);
    }

    searchBar.addEventListener('input', applyFilterAndRender);

    // Sistema Desplegable (Modal) para desglozar los Appends / Versiones
    window.openModal = function(id) {
        const character = characterArchive[id];
        const modal = document.getElementById('versionsModal');
        const latest = character.versions[character.versions.length - 1];
        
        document.getElementById('modalCharacterTitle').innerText = `Historial de ${id}`;
        document.getElementById('modalCharacterSubtitle').innerText = `Total de voicebanks registrados: ${character.versions.length}`;
        
        const listContainer = document.getElementById('versionsList');
        listContainer.innerHTML = "";

        // Mostramos la lista de versiones ordenadas (de la más nueva a la más antigua)
        [...character.versions].reverse().forEach(v => {
            const item = document.createElement('div');
            item.className = 'version-item';
            item.innerHTML = `
                <img class="version-img" src="${v.img}" onerror="this.src='https://via.placeholder.com/80?text=No+Image'">
                <div class="version-details">
                    <div class="version-name">${v.name}</div>
                    <div class="meta-line"><strong>Software:</strong> ${v.software} | <strong>Lanzamiento:</strong> ${v.date}</div>
                    <div class="meta-line"><strong>Idiomas:</strong> ${v.lang} | <strong>Género:</strong> ${v.gender}</div>
                    <button class="modal-play-btn" onclick="playAudio('${v.demo}', this)">▶ Escuchar Demo</button>
                </div>
                <a href="${v.web}" target="_blank" class="btn-official-web">Sitio Oficial ↗</a>
            `;
            listContainer.appendChild(item);
        });

        modal.style.display = "flex";
    };

    window.closeModal = function() {
        document.getElementById('versionsModal').style.display = "none";
        globalAudio.pause();
    };

    // Controlador de Audio
    window.playAudio = function(url, button) {
        if (globalAudio.src === url && !globalAudio.paused) {
            globalAudio.pause();
            button.innerText = button.innerText.includes("DEMO") ? "▶ DEMO RECIENTE" : "▶ Escuchar Demo";
        } else {
            document.querySelectorAll('.play-btn, .modal-play-btn').forEach(btn => {
                if(btn.classList.contains('play-btn')) btn.innerText = "▶ DEMO RECIENTE";
                else btn.innerText = "▶ Escuchar Demo";
            });
            globalAudio.src = url;
            globalAudio.play();
            button.innerText = "⏸ PAUSAR";
        }
    };

    applyFilterAndRender();
</script>

</body>
</html>
